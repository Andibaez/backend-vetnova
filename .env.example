# ─────────────────────────────────────────────
# VetNova Backend — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────

# Base de datos PostgreSQL (requerido)
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB?schema=public
# Ejemplo NeonDB: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/vetnova?sslmode=require
DATABASE_URL="postgresql://usuario:password@localhost:5432/vetnova_db?schema=public"

# Puerto del servidor (opcional, defecto 3000)
PORT=3000

# Orígenes permitidos para CORS (separados por coma, sin espacios)
# Ejemplo producción: https://vetnova.vercel.app
ALLOWED_ORIGINS="http://localhost:3001"

# JWT — para autenticación (cuando se implemente)
JWT_SECRET="cambia-esto-por-un-secreto-de-al-menos-32-caracteres-aleatorios"
JWT_EXPIRES_IN="1d"
