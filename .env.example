# ─────────────────────────────────────────────
# VetNova Backend — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────

# Base de datos PostgreSQL (requerido)
# DATABASE_URL  → URL del pooler (para queries en runtime) — incluye -pooler en el host
# DIRECT_URL    → URL directa (para prisma db push/migrate) — sin -pooler en el host
# En NeonDB: copia ambas URLs desde Connection Details, la pooler y la directa
DATABASE_URL="postgresql://usuario:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://usuario:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Puerto del servidor (opcional, defecto 3000)
PORT=3000

# Orígenes permitidos para CORS (separados por coma, sin espacios)
# Ejemplo producción: https://vetnova.vercel.app
ALLOWED_ORIGINS="http://localhost:3001"

# JWT — para autenticación (cuando se implemente)
JWT_SECRET="cambia-esto-por-un-secreto-de-al-menos-32-caracteres-aleatorios"
JWT_EXPIRES_IN="1d"

# Google OAuth — Client ID del proyecto en Google Cloud Console
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
