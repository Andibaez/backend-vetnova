<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <title>VetNova</title>
    <!--[if mso]>
    <style>
      table { border-collapse: collapse; }
      .fallback-bg { background-color: #5457E5 !important; }
    </style>
    <![endif]-->
    <style>
      /* Animación sutil: clientes que ignoran @keyframes en el <head> (Outlook,
         Gmail app) simplemente la omiten y el badge queda estático — no rompe nada. */
      @keyframes badge-pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.18); opacity: 0.55; }
      }
      @keyframes card-fade-in {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .badge-dot {
        animation: badge-pulse 1.8s ease-in-out infinite;
      }
      .email-card {
        animation: card-fade-in 0.5s ease-out;
      }
      @media (prefers-reduced-motion: reduce) {
        .badge-dot, .email-card { animation: none !important; }
      }
    </style>
  </head>
  <body style="margin:0; padding:0; background-color:#F8F8FC; font-family: Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F8F8FC; padding:32px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="email-card" style="max-width:560px; background-color:#FFFFFF; border-radius:16px; overflow:hidden; box-shadow:0 1px 2px rgba(15,23,42,0.04), 0 8px 24px rgba(15,23,42,0.06);">
            <tr>
              <td class="fallback-bg" style="background-color:#5457E5; background-image:linear-gradient(135deg, #5457E5 0%, #6366F1 60%, #818CF8 100%); padding:28px 32px;">
                <table role="presentation" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="vertical-align:middle; padding-right:12px;">
                      <img src="https://vetnova.online/logos/vetnova-icon-white.png" width="34" height="34" alt="VetNova" style="display:block; width:34px; height:34px;" />
                    </td>
                    <td style="vertical-align:middle;">
                      <span style="font-size:21px; font-weight:bold; letter-spacing:-0.01em; color:#FFFFFF;">VetNova</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:32px;">
                {{{body}}}
              </td>
            </tr>
            <tr>
              <td style="padding:20px 32px; background-color:#FAFAFD; border-top:1px solid #EAEAEA;">
                <p style="margin:0 0 4px; font-size:12px; color:#9CA3AF; text-align:center;">
                  Este es un correo automático de VetNova. Por favor no respondas a este mensaje.
                </p>
                <p style="margin:0; font-size:12px; color:#A5B4FC; text-align:center;">
                  <a href="https://vetnova.online" style="color:#5457E5; text-decoration:none; font-weight:bold;">vetnova.online</a>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
